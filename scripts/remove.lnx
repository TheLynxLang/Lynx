Roar "🐾 Removing package: " + __pkg

KittyReadFile "lynx.toml"
Set content = __file_content

Set found = 0
Set new_content = ""
KittySplitString content "\n"
Set lines_count = __result_count

For i = 0 To lines_count - 1 {
    Set line = __result[i]
    KittyCheckIfStringContains line (__pkg + " = ")
    If __result == 1 {
        Set found = 1
        Continue
    }
    Set new_content = new_content + line + "\n"
}

If found == 0 {
    Roar "⚠️ " + __pkg + " not found in dependencies"
    Return
}

KittyWriteFile "lynx.toml" new_content

KittyFileExists "lynx.lock"
If __result == 1 {
    KittyReadFile "lynx.lock"
    Set lockContent = __file_content
    Set newLock = ""
    KittySplitString lockContent "\n"
    Set lock_lines_count = __result_count
    For i = 0 To lock_lines_count - 1 {
        Set line = __result[i]
        KittyCheckIfStringContains line (__pkg + " = ")
        If __result == 1 {
            Continue
        }
        Set newLock = newLock + line + "\n"
    }
    KittyWriteFile "lynx.lock" newLock
}

Run "rmdir /s /q libs\\" + __pkg

Set cachePath = getenv("USERPROFILE") + "\\.lynx\\cache\\" + __pkg + "_*.tar.gz"
Run "del /q " + cachePath

Roar "✅ Removed " + __pkg