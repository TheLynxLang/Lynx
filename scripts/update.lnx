Roar "🐾 Updating packages..."

Set tempDir = getenv("TEMP")
Set jsonFile = tempDir + "\\packages.json"

Run "powershell -command \"Invoke-WebRequest -Uri https://raw.githubusercontent.com/justdev-chris/lynx-registry/main/packages.json -OutFile " + jsonFile + "\""

KittyReadFile jsonFile
Set json = __file_content

KittyReadFile "lynx.toml"
Set content = __file_content
KittySplitString(content, "\n")
Set lines_count = __result_count
Set in_deps = 0
Set new_toml = ""
Set updated = 0

For i = 0 To lines_count - 1 {
    Set line = __result[i]
    
    If KittyCheckIfStringContains(line, "[dependencies]") {
        in_deps = 1
        new_toml = new_toml + line + "\n"
        Continue
    }
    
    If in_deps == 1 {
        If line == "" { 
            new_toml = new_toml + line + "\n"
            Continue 
        }
        If KittyCheckIfStringContains(line, "[") {
            in_deps = 0
            new_toml = new_toml + line + "\n"
            Continue
        }
        
        KittySplitString(line, "=")
        If __result_count >= 2 {
            Set pkg = Trim(__result[0])
            Set old_version = Trim(__result[1])
            old_version = KittyReplaceString(old_version, "\"", "")
            
            KittySplitString(json, "\n")
            Set json_lines_count = __result_count
            Set new_version = ""
            
            For j = 0 To json_lines_count - 1 {
                Set jline = __result[j]
                If KittyCheckIfStringContains(jline, "\"" + pkg + "\"") {
                    For k = j To j + 10 {
                        If k < json_lines_count {
                            Set vline = __result[k]
                            If KittyCheckIfStringContains(vline, "version") {
                                KittySplitString(vline, ":")
                                If __result_count >= 2 {
                                    Set new_version = Trim(__result[1])
                                    Set new_version = KittyReplaceString(new_version, "\"", "")
                                    Set new_version = KittyReplaceString(new_version, ",", "")
                                    Break
                                }
                            }
                        }
                    }
                    Break
                }
            }
            
            If Len(new_version) > 0 {
                Roar "📦 Updating " + pkg + " (" + old_version + " → " + new_version + ")"
                new_toml = new_toml + pkg + " = \"" + new_version + "\"\n"
                Set updated = updated + 1
            } Else {
                Roar "⚠️ " + pkg + " not found in registry, keeping " + old_version
                new_toml = new_toml + line + "\n"
            }
        }
    } Else {
        new_toml = new_toml + line + "\n"
    }
}

KittyWriteFile "lynx.toml" new_toml

If updated > 0 {
    Roar "🔄 Reinstalling updated packages..."
    Run "lynx install"
    Roar "✅ Updated " + updated + " package(s)"
} Else {
    Roar "✅ All packages up to date"
}

Run "del /q " + jsonFile